              "path": ["v3", "api-docs"]
            }
          }
        }
      ]
    },
    {
      "name": "6. Case lỗi & biên (validation / conflict / rate limit)",
      "item": [
        {
          "name": "Tạo SP - status sai (expect 400 validation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
                  "pm.test('Có thông báo lỗi field', () => pm.expect(pm.response.json().message).to.include('status'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SP-BAD-001\",\n  \"name\": \"San pham status sai\",\n  \"category\": \"FTTH\",\n  \"status\": \"KHONG_HOP_LE\",\n  \"description\": \"status khong thuoc ACTIVE|INACTIVE|RETIRED\"\n}"
            },
            "url": {
              "raw": "{{managementUrl}}/api/v1/management/products",
              "host": ["{{managementUrl}}"],
              "path": ["api", "v1", "management", "products"]
            },
            "description": "status vi phạm @Pattern(ACTIVE|INACTIVE|RETIRED) -> MethodArgumentNotValidException -> GlobalExceptionHandler trả 400."
          }
        },
        {
          "name": "Tạo SP - thiếu trường bắt buộc (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"FTTH\"\n}"
            },
            "url": {
              "raw": "{{managementUrl}}/api/v1/management/products",
              "host": ["{{managementUrl}}"],
              "path": ["api", "v1", "management", "products"]
            },
            "description": "Thiếu code/name/status (@NotBlank) -> 400."
          }
        },
        {
          "name": "Tạo SP trùng code (expect 409 Conflict)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 lần đầu hoặc 409 nếu đã tồn tại', () => pm.expect(pm.response.code).to.be.oneOf([201, 409]));",
                  "if (pm.response.code === 409) { pm.test('Thông báo trùng code', () => pm.expect(pm.response.json().message).to.include('exists')); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SP-DUP-FIXED-001\",\n  \"name\": \"San pham trung code\",\n  \"category\": \"FTTH\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{managementUrl}}/api/v1/management/products",
              "host": ["{{managementUrl}}"],
              "path": ["api", "v1", "management", "products"]
            },
            "description": "Chạy lần 1 -> 201. Chạy lại -> existsByCode=true -> ResponseStatusException(409 CONFLICT). Minh chứng ràng buộc unique code."
          }
        },
        {
          "name": "Cập nhật SP không tồn tại (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"SP-NONE\",\n  \"name\": \"x\",\n  \"category\": \"FTTH\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{managementUrl}}/api/v1/management/products/khong-ton-tai-999",
              "host": ["{{managementUrl}}"],
              "path": ["api", "v1", "management", "products", "khong-ton-tai-999"]
            }
          }
        },
        {
          "name": "Liệt kê SP - lọc theo category & status",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{catalogUrl}}/api/v1/products?page=0&size=50&category=FTTH&status=ACTIVE",
              "host": ["{{catalogUrl}}"],
              "path": ["api", "v1", "products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "50" },
                { "key": "category", "value": "FTTH" },
                { "key": "status", "value": "ACTIVE" }
              ]
            }
          }
        },
        {
          "name": "Validate khi KHÔNG có token (active=false)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK (trả introspection)', () => pm.response.to.have.status(200));",
                  "pm.test('active=false', () => pm.expect(pm.response.json().active).to.eql(false));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{integrationUrl}}/api/v1/integration/validate",
              "host": ["{{integrationUrl}}"],
              "path": ["api", "v1", "integration", "validate"]
            },
            "description": "Không gửi Authorization -> trả {active:false, error:missing_bearer_token}."
          }
        },
        {
          "name": "Rate limit - bắn liên tục (kỳ vọng có 429)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Lưu ý: rate limit áp ở Gateway (:8080) cho route đã xác thực.",
                  "// Để thấy 429, cần token hợp lệ và bắn vượt replenishRate (200/s).",
                  "// Dùng Collection Runner với số vòng lặp lớn trên request này.",
                  "pm.test('Status 200/401/429 hợp lệ', () => pm.expect(pm.response.code).to.be.oneOf([200, 401, 429]));",
                  "if (pm.response.code === 429) { pm.test('Đã chạm rate limit', () => true); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/api/v1/products/{{productId}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "v1", "products", "{{productId}}"]
            },
            "description": "RequestRateLimiter theo clientId (token-bucket Redis). Chạy nhiều vòng để kích hoạt HTTP 429."
          }
        }
      ]
    }
  ],
  "variable": [
