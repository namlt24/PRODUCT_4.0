              "raw": "{{catalogUrl}}/actuator/prometheus",
              "host": ["{{catalogUrl}}"],
              "path": ["actuator", "prometheus"]
            },
            "description": "JVM, HikariCP pool (catalog-read-pool), cache, Kafka consumer lag, http request rate/latency."
          }
        },
        {
          "name": "Catalog - Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{catalogUrl}}/actuator/health",
