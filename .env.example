# ============================================================================
# BCCS Product Catalog Platform - Environment Variables
# Copy to ".env" and fill real values. NEVER commit the real .env file.
# Secrets are injected at runtime; no DB credentials live in YAML.
# ============================================================================

# ---- MariaDB (shared schema between microservices) ----
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=bccs_catalog
DB_USER=bccs_app
DB_PASSWORD=ChangeMe_Str0ng_Pass
# root password only used by the local docker-compose mariadb container
MARIADB_ROOT_PASSWORD=ChangeMe_R00t_Pass

# ---- Redis Cluster (L2 cache + rate limiter) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ---- JWT / Auth ----
# Base64-encoded RSA public key (PEM body) used for in-memory token validation at the gateway.
JWT_PUBLIC_KEY=
# 3rd-party Auth provider base URL (token introspection / validation fallback)
THIRD_PARTY_AUTH_URL=https://auth.partner.example.com

# ---- Observability ----
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000
SERVICE_ENV=local
